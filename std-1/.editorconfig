# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Java files
[*.java]
indent_size = 4
max_line_length = 120

# JavaScript / TypeScript / Vue
[{*.js,*.ts,*.vue}]
indent_size = 2
max_line_length = 100

# JSON files
[*.json]
indent_size = 2

# XML files
[*.xml]
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Python files
[*.py]
indent_size = 4
max_line_length = 88

# Shell scripts
[*.sh]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab